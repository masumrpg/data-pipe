{
  "$schema": "../pipeline.schema.json",
  "name": "Quran Relational Seeding",
  "version": "1.0",

  "source": {
    "type": "api",
    "pagination": {
      "type": "range",
      "param": "index",
      "from": 1,
      "to": 114
    },
    "requests": [
      {
        "id": "equran",
        "url": "https://equran.id/api/v2/surat/{index}",
        "resultPath": "data"
      },
      {
        "id": "tafsir",
        "url": "https://equran.id/api/v2/tafsir/{index}",
        "resultPath": "data"
      }
    ],
    "mergeKey": "index",
    "delayMs": 300
  },

  "target": {
    "type": "postgres",
    "connectionString": "postgresql://ma-sum@localhost:5432/alquran",
    "table": "v_quran_import",
    "schema": "quran"
  },

  "operation": {
    "mode": "insert"
  },

  "mapping": [
    { "from": "equran.nomor",      "to": "m_surahs.number" },
    { "from": "equran.nama",       "to": "m_surahs.name" },
    { "from": "equran.namaLatin",  "to": "m_surahs.latin_name" },
    { "from": "equran.jumlahAyat", "to": "m_surahs.total_verses", "transform": "toInt" },
    { "from": "equran.tempatTurun", "to": "m_surahs.revelation_place" },
    { "from": "equran.arti",       "to": "m_surahs.translation" },
    { "from": "equran.deskripsi",  "to": "m_surahs.description" },
    { "from": "equran.audioFull",  "to": "m_surahs.full_audio", "transform": "toJsonString" },
    {
      "from": "equran.ayat",
      "to": "_expand",
      "expand": true,
      "mapping": [
        { "from": "nomorAyat",     "to": "m_ayats.verse_number", "transform": "toInt" },
        { "from": "teksArab",      "to": "m_ayats.arabic_text" },
        { "from": "teksLatin",     "to": "m_ayats.latin_text" },
        { "from": "teksIndonesia", "to": "m_ayats.indonesian_text" },
        { "from": "audio.01",      "to": "m_ayat_audio.audio_01" },
        { "from": "audio.02",      "to": "m_ayat_audio.audio_02" },
        { "from": "audio.03",      "to": "m_ayat_audio.audio_03" },
        { "from": "audio.04",      "to": "m_ayat_audio.audio_04" },
        { "from": "audio.05",      "to": "m_ayat_audio.audio_05" },
        { "from": "audio.06",      "to": "m_ayat_audio.audio_06" },
        { "from": "nomorAyat",     "to": "m_tafsir.verse_number", "transform": "toInt" },
        { "from": "tafsir.tafsir[nomorAyat].teks", "to": "m_tafsir.text" }
      ]
    }
  ]
}
