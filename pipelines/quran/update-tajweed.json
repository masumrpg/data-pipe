{
  "$schema": "../pipeline.schema.json",
  "name": "Quran Tajweed Update",
  "version": "1.0",

  "source": {
    "type": "json",
    "filePath": "pipelines/quran/input/quran-tajweed.json",
    "resultPath": "quran.quran-tajweed"
  },

  "target": {
    "type": "postgres",
    "connectionString": "postgresql://ma-sum@localhost:5432/quran_pipe_data",
    "table": "ayats"
  },

  "operation": {
    "mode": "update",
    "updateWhere": [
      { "column": "surah_number" },
      { "column": "verse_number" }
    ]
  },

  "mapping": [
    { "from": "surah", "to": "surah_number", "transform": "toInt" },
    { "from": "ayah",  "to": "verse_number", "transform": "toInt" },
    { "from": "verse", "to": "tajweed_arabic_text" }
  ]
}
