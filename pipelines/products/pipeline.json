{
  "$schema": "../pipeline.schema.json",
  "name": "Import Products from CSV",
  "version": "1.0",

  "source": {
    "type": "csv",
    "filePath": "./pipelines/products/input/products.csv",
    "delimiter": ",",
    "hasHeader": true
  },

  "target": {
    "type": "sqlite",
    "filePath": "./pipelines/products/output/products.db",
    "table": "products"
  },

  "operation": {
    "mode": "upsert",
    "conflictOn": ["sku"]
  },

  "mapping": [
    { "from": "SKU",       "to": "sku" },
    { "from": "Name",      "to": "name" },
    { "from": "Price",     "to": "price",      "transform": "toFloat" },
    { "from": "Stock",     "to": "stock",      "transform": "toInt" },
    { "from": "UpdatedAt", "to": "updated_at", "transform": "toISODate" }
  ]
}
