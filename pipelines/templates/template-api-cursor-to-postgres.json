{
  "$schema": "./../pipeline.schema.json",
  "name": "___NAMA_PIPELINE___",
  "version": "1.0",

  "source": {
    "type": "api",
    "pagination": {
      "type": "cursor",
      "param": "___NAMA_PARAM_CURSOR___",
      "nextPath": "___DOT.PATH.KE.NEXT_CURSOR___"
    },
    "requests": [
      {
        "id": "___ID_REQUEST___",
        "url": "https://___DOMAIN___/___PATH___?limit=100",
