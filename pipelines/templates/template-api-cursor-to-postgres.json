    "table": "___NAMA_TABEL___"
  },

  "operation": {
    "mode": "___insert_ATAU_upsert_ATAU_update___",
    "conflictOn": ["___KOLOM_UNIK___"]
  },

  "mapping": [
    { "from": "___field___", "to": "___kolom_db___" },
    { "from": "___field___", "to": "___kolom_db___", "transform": "___toInt|toFloat|toString|toISODate|toLower|toUpper|trim|nullIfEmpty___" }
  ]
}
